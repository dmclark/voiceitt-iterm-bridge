#!/bin/bash
# voiceitt-transform — read dictated text on stdin, write LLM-cleaned text on stdout.
#
# v0: hardcoded provider (Google AI Studio / Gemini 2.5 Flash). The system
# prompt is loaded from $VOICEITT_BRIDGE_DIR/prompts/default.md (symlinked
# to the repo's prompts/default.md by install.sh). The picker (§1.2) and
# active-prompt sidecar (§1.4) aren't wired yet, so default.md is always
# used.
#
# Bug fix (ERD §1.3): the dictated text is wrapped in <TRANSCRIPT>…</TRANSCRIPT>
# before being sent as the user message. Without this framing — and without
# the matching default.md system prompt that explains what <TRANSCRIPT> means
# — utterances like "make a directory called src" were being interpreted by
# the LLM as commands to execute rather than transcripts to clean up.
#
# Usage:
#   echo "um so like make a directory called source" | scripts/voiceitt-transform
#
# Requires:
#   - GOOGLE_API_KEY in env (get one at https://aistudio.google.com/apikey)
#   - curl, jq

set -e

if [ -z "$GOOGLE_API_KEY" ]; then
  echo "voiceitt-transform: GOOGLE_API_KEY is not set" >&2
  exit 2
fi

for cmd in curl jq; do
  if ! command -v "$cmd" >/dev/null 2>&1; then
    echo "voiceitt-transform: required command '$cmd' not found on PATH" >&2
    exit 2
  fi
done

MODEL="${VOICEITT_TRANSFORM_MODEL:-gemini-2.5-flash-lite}"
# REVISIT: default timeout. 6s chosen for v0 standalone testing because
# observed gemini-2.5-flash latency is ~1–5s with occasional outliers above
# 2.5s. When the send-to-* wrappers gain a fail-open-to-raw-clipboard path,
# this should drop back to ~2.5s so a slow API call doesn't visibly hang
# the paste hotkey. Or switch the default model to gemini-2.5-flash-lite,
# which is typically sub-second.
TIMEOUT="${VOICEITT_TRANSFORM_TIMEOUT:-6}"

# Load the system prompt from prompts/default.md. We resolve it relative to
# the script's real path (following symlinks) so this works whether the
# script is invoked from the repo or via the install.sh symlink at
# ~/.config/voiceitt-bridge/voiceitt-transform.
SCRIPT_REAL="$(python3 -c 'import os, sys; print(os.path.realpath(sys.argv[1]))' "$0")"
SCRIPT_DIR="$(dirname "$SCRIPT_REAL")"
PROMPT_FILE="${VOICEITT_BRIDGE_CONFIG:-$HOME/.config/voiceitt-bridge}/prompts/default.md"
if [ ! -f "$PROMPT_FILE" ]; then
  # Fallback: look next to the script in the repo (scripts/ -> ../prompts/).
  PROMPT_FILE="$SCRIPT_DIR/../prompts/default.md"
fi
if [ ! -f "$PROMPT_FILE" ]; then
  echo "voiceitt-transform: cannot find prompts/default.md (looked in \$VOICEITT_BRIDGE_CONFIG/prompts and $SCRIPT_DIR/../prompts)" >&2
  exit 2
fi
SYSTEM="$(cat "$PROMPT_FILE")"

INPUT="$(cat)"

# If stdin is empty, pass through unchanged.
if [ -z "$INPUT" ]; then
  exit 0
fi

# Wrap the dictated text in <TRANSCRIPT>…</TRANSCRIPT> so the LLM treats
# it as input to clean rather than instructions to follow. The default.md
# prompt expects exactly this framing.
USER_MSG="<TRANSCRIPT>
${INPUT}
</TRANSCRIPT>"

REQUEST="$(jq -n --arg s "$SYSTEM" --arg u "$USER_MSG" '{
  system_instruction: { parts: [{ text: $s }] },
  contents:           [{ role: "user", parts: [{ text: $u }] }],
  generationConfig:   { temperature: 0.2 }
}')"

# Capture body and HTTP status in one round-trip. We append the status code
# on its own trailing line via -w so a 5xx with a JSON error body still gets
# surfaced (curl -sS without -f exits 0 on HTTP errors, so the previous
# version silently fed the error JSON to jq, then died with set -e on the
# missing .candidates path — masking the real upstream cause behind the
# bridge's generic 502).
STATUS_SENTINEL=$'\n__HTTP_STATUS__:'
# `set +e` around curl so we can log what it actually managed to write
# (partial body, error JSON, etc.) before bailing. With `set -e` the
# previous version threw away $RAW on any non-zero curl exit, which hid
# things like a 503 HTML page that arrived before the connection dropped.
set +e
RAW="$(curl -sS --max-time "$TIMEOUT" \
  -w "${STATUS_SENTINEL}%{http_code}" \
  "https://generativelanguage.googleapis.com/v1beta/models/${MODEL}:generateContent?key=${GOOGLE_API_KEY}" \
  -H "content-type: application/json" \
  -d "$REQUEST" 2>/tmp/voiceitt-curl-err.$$)"
CURL_EXIT=$?
set -e

CURL_STDERR="$(cat /tmp/voiceitt-curl-err.$$ 2>/dev/null || true)"
rm -f /tmp/voiceitt-curl-err.$$

if [ "$CURL_EXIT" -ne 0 ]; then
  echo "voiceitt-transform: curl exited ${CURL_EXIT} (timeout cap ${TIMEOUT}s)." >&2
  if [ -n "$CURL_STDERR" ]; then
    echo "voiceitt-transform: curl stderr:" >&2
    echo "$CURL_STDERR" >&2
  fi
  # Only log a "partial body" block if curl actually wrote one. With the
  # -w sentinel, an aborted request still leaves `\n__HTTP_STATUS__:000`
  # in $RAW; skip when the body before the sentinel is empty.
  PARTIAL_BODY="${RAW%${STATUS_SENTINEL}*}"
  if [ -n "$PARTIAL_BODY" ]; then
    echo "voiceitt-transform: partial response body before failure:" >&2
    echo "$PARTIAL_BODY" >&2
  fi
  exit 1
fi

# curl's own stderr (e.g. retried-redirect notices under -S) is worth
# preserving even on success-ish runs; pass it through so it lands in
# server.log alongside whatever happens next.
if [ -n "$CURL_STDERR" ]; then
  echo "$CURL_STDERR" >&2
fi

HTTP_CODE="${RAW##*__HTTP_STATUS__:}"
RESPONSE="${RAW%${STATUS_SENTINEL}*}"

if [ "$HTTP_CODE" != "200" ]; then
  echo "voiceitt-transform: Gemini returned HTTP ${HTTP_CODE}. Raw response:" >&2
  echo "$RESPONSE" >&2
  exit 1
fi

# Don't let a non-JSON 200 (rare, but seen with intermediary error pages)
# crash the script silently under set -e — capture jq's exit and log the
# raw body if parsing fails.
CLEANED="$(jq -r '.candidates[0].content.parts[0].text // empty' <<<"$RESPONSE" 2>/tmp/voiceitt-jq-err.$$)" || {
  echo "voiceitt-transform: failed to parse Gemini response as JSON. jq stderr:" >&2
  cat /tmp/voiceitt-jq-err.$$ >&2 || true
  rm -f /tmp/voiceitt-jq-err.$$
  echo "voiceitt-transform: raw response:" >&2
  echo "$RESPONSE" >&2
  exit 1
}
rm -f /tmp/voiceitt-jq-err.$$

if [ -z "$CLEANED" ]; then
  echo "voiceitt-transform: empty .candidates[0].content.parts[0].text from Gemini. Raw response:" >&2
  echo "$RESPONSE" >&2
  exit 1
fi

printf '%s' "$CLEANED"
